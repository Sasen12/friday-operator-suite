# Default output folder for Friday's short-form video projects
FRIDAY_SHORTS_OUTPUT_ROOT=C:/Edits/AI Vids

# Path to a local shorts_maker checkout, if you want local rendering
SHORTS_MAKER_DIR=

# Local speech stack (Whisper + Piper)
FRIDAY_SPEECH_PROVIDER=local
FRIDAY_STT_PROVIDER=local
FRIDAY_TTS_PROVIDER=local

# Local Whisper settings
FRIDAY_LOCAL_STT_MODEL=base.en
FRIDAY_LOCAL_STT_DEVICE=cpu
FRIDAY_LOCAL_STT_COMPUTE_TYPE=int8
FRIDAY_LOCAL_STT_LANGUAGE=en
FRIDAY_LOCAL_STT_DOWNLOAD_ROOT=
FRIDAY_LOCAL_STT_OFFLINE=0

# Local Piper settings
FRIDAY_LOCAL_TTS_MODEL=en_US-lessac-medium
FRIDAY_LOCAL_TTS_CONFIG=
FRIDAY_LOCAL_TTS_DOWNLOAD_DIR=
FRIDAY_LOCAL_TTS_USE_CUDA=0
FRIDAY_LOCAL_TTS_VOLUME=1.0

# Optional local Ollama LLM settings
FRIDAY_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1/
OLLAMA_LLM_MODEL=gemma4

# Legacy cloud mode only
# LiveKit credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
